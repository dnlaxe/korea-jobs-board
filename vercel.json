{
    "version": 2,
    "routes": [
        {
            "src": "/(.*)",
            "check": true,
            "dest": "src/app.ts"
        },
        {
            "src": "/(.*)",
            "dest": "src/app.ts"
        }
    ],
    "functions": {
        "src/app.ts": {
            "includeFiles": "views/**/*"
        }
    }
}