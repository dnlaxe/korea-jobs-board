  <div class="sticky top-[37px] z-30 bg-blue-200/90">
    <p
      href="/jobs/board"
      class="flex w-full items-center justify-center px-3 py-2 text-sm font-mono uppercase tracking-wider"
    >
      Your drafts
    </p>
  </div>

<div class="p-4">
  <div class="flex flex-col gap-8">

    {{#if actionError}}
      <p class="text-red-500 text-sm border border-red-500 py-1 px-2  inline-block">{{actionError}}</p>
    {{/if}}

    {{#if loadError}}
      <p class="text-red-500 text-sm border border-red-500 py-1 px-2  inline-block">Could not load drafts.</p>
    {{else}}


        <div class="flex flex-col gap-4">
          {{#each drafts}}
            <div class="border border-slate-200 p-2">
              <div class="md:flex md:flex-row border mb-2">
                <div class="md:flex-1 md:flex md:flex-col p-4 pb-0 md:pb-4">
                  <div class="text-xl mb-2">{{heading}}</div>
                  <div>{{subheading}}</div>
                </div>
                <div class="flex flex-col gap-1 md:w-60 p-4 font-mono uppercase text-sm tracking-wide">
                  <span><i class="ph ph-read-cv-logo mr-2"></i>{{specialization}}</span>
                  <span><i class="ph ph-calendar-dot mr-2"></i>{{startDate}}</span>
                  <span><i class="ph ph-map-pin-area mr-2"></i>{{city}}, {{province}}</span>
                  <span><i class="ph ph-hourglass-high mr-2"></i>{{contractType}}</span>
                </div>
              </div>

                  <fieldset>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                      <label class="cursor-pointer h-full">
                        <input
                          type="radio"
                          name="{{this.id}}"
                          value="standard"
                          form="drafts-checkout-form"
                          class="sr-only peer"
                          {{#if (eq this.tier "pinned")}}{{else}}checked{{/if}}
                        />
                        <div class="flex flex-col h-full px-3 py-2  border border-slate-200 peer-checked:border-black peer-checked:bg-white peer-checked:text-black">
                          <div class="flex justify-between mb-1 text-lg">
                            <span class="uppercase">Standard</span>
                            <span>Free</span>
                          </div>
                          <ul class="flex flex-col gap-2 mt-2">
                            <li>Listed for thirty days</li>
                            <li>Management link</li>
                          </ul>
                        </div>
                      </label>
                      <label class="cursor-pointer h-full">
                        <input
                          type="radio"
                          name="{{this.id}}"
                          value="pinned"
                          form="drafts-checkout-form"
                          class="sr-only peer"
                          {{#if (eq this.tier "pinned")}}checked{{/if}}
                        />
                        <div class="flex flex-col h-full px-3 py-2 border border-slate-200 peer-checked:border-black peer-checked:bg-white peer-checked:text-black">
                          <div class="flex justify-between text-lg mb-1">
                            <span class="uppercase">Pinned</span>
                            <span>$10</span>
                          </div>
                          <ul class="flex flex-col gap-2 mt-2">
                            <li><i class="ph ph-check text-blue-500 mr-2"></i>Pinned to the top of all listings</li>
                            <li><i class="ph ph-check text-blue-500 mr-2"></i>Pinned for thirty days</li>
                            <li><i class="ph ph-check text-blue-500 mr-2"></i>Link management</li>
                          </ul>
                        </div>
                      </label>
                    </div>
                  </fieldset>

                                      <div class="flex flex-row justify-end mt-2">
                    <form method="POST" action="/jobs/drafts/{{this.id}}/delete">
                      <button
                        type="button"
                        class="font-mono uppercase tracking-wide underline text-sm text-red-500"
                        data-delete-trigger
                      >
                        Delete
                      </button>
                    </form>
                  </div>

              </div>


        {{else}}
          <p class="p-4">No drafts yet.</p>
        {{/each}}
      </div>
    {{/if}}

    <div class="flex flex-row justify-between">
      <a href="/jobs/new" class="flex items-center justify-center border px-3 py-2 text-sm font-mono tracking-wide uppercase text-center">{{#unless drafts}}Add a job{{else}}Add another job{{/unless}}</a>
      <form
        id="drafts-checkout-form"
        method="POST"
        action="/jobs/drafts/checkout"
      >
        <button
          type="submit"
          data-checkout-submit
          class="px-3 py-2 text-sm font-mono tracking-wide text-center uppercase border"
        >Pay and submit</button>
      </form>
    </div>
  </div>
</div>

{{> confirm-modal
  id="delete-draft"
  title="Delete draft?"
  message="This draft will be permanently removed."
  confirmLabel="Delete"
  cancelLabel="Cancel"
}}

<script src="/js/payment/calculate.js" defer></script>
<script src="/js/delete-button.js" defer></script>
