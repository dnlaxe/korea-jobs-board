<div
  class="fixed inset-0 z-50 hidden justify-center bg-black/40 p-4 items-center"
  data-confirm-modal
  aria-hidden="true"
>
  <div
    class="w-full max-w-md border border-slate-200 bg-white p-6 shadow-lg"
    role="dialog"
  >
    <div class="flex flex-col gap-3">
      <h2 id="{{id}}-title" class="text-xl font-semibold tracking-wide">
        {{title}}
      </h2>

      <p id="{{id}}-description">
        {{message}}
      </p>

      <div class="mt-2 flex flex-row justify-between">
        <button
          type="button"
          class="border px-3 py-2 font-mono uppercase tracking-wide text-sm"
          data-confirm-cancel
        >
          {{#if cancelLabel}}{{cancelLabel}}{{else}}Cancel{{/if}}
        </button>

        <button
          type="button"
          class="border border-red-500 px-3 py-2 font-mono uppercase tracking-wide text-sm text-red-500 hover:bg-red-500 hover:text-white"
          data-confirm-accept
        >
          {{#if confirmLabel}}{{confirmLabel}}{{else}}Delete{{/if}}
        </button>
      </div>
    </div>
  </div>
</div>