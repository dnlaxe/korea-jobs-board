<div class="p-4">
  <h1 class="text-2xl mb-4">Dummy Payment</h1>
  <p class="mb-4">Payment ref: {{paymentRef}}</p>

  <div class="flex gap-2">
    <form method="POST" action="/dummy-payment/complete">
      <input type="hidden" name="paymentRef" value="{{paymentRef}}" />
      <button type="submit" class="border px-4 py-2">Pay now</button>
    </form>

    <form method="POST" action="/dummy-payment/cancel">
      <input type="hidden" name="paymentRef" value="{{paymentRef}}" />
      <button type="submit" class="border px-4 py-2">Cancel</button>
    </form>
  </div>
</div>
